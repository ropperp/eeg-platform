# Datenbank
DB_USER=eeg
DB_PASSWORD=change-this-password
DB_NAME=eeg_platform

# Domain (ohne https://) -- wird für Traefik-Routing verwendet (Host(`${DOMAIN}`) etc.)
DOMAIN=deine-domain.at

# App
APP_SECRET=change-this-to-a-random-64-char-string

# latex-service
LATEX_API_KEY=change-this-api-key

# E-Mail (Brevo, Postmark, ... -- optional, kann leer bleiben und später über
# Platform-Admin -> E-Mail-Einstellungen per Microsoft Graph konfiguriert werden)
SMTP_HOST=smtp-relay.brevo.com
SMTP_USER=
SMTP_PASSWORD=
