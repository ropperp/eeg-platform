# ============================================================
# Traefik Umgebungsvariablen — Vorlage
# Kopieren:  cp .env.example .env  und Werte eintragen
# ============================================================

# BasicAuth für das Traefik-Dashboard
# Erzeugen mit: htpasswd -nb admin DEINPASSWORT
# WICHTIG in .env-Datei: jedes $ im Hash VERDOPPELN zu $$
# Beispiel (Passwort: "geheim"):
#   TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$xyz123$$abcdefghijklmnopqrstu0
#
# In Portainer Env-Vars: dort nur EIN $ eintragen (Portainer escaped nicht)
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$ERSETZEN$$HASH_HIER_EINTRAGEN
