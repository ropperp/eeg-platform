# ═══════════════════════════════════════════════════════
# NIEMALS COMMITTEN — Secrets und personenbezogene Daten
# ═══════════════════════════════════════════════════════

# Umgebungsvariablen (Passwörter, API-Keys, Domain)
.env

# Datenbank-Dumps (enthalten echte Mitgliederdaten: Namen, IBAN, Verbrauch)
backups/

# Uploads und generierte PDFs (Laufzeitdaten, personenbezogen)
/webapp/storage/uploads/*
/webapp/storage/pdfs/*
!/webapp/storage/uploads/.gitkeep
!/webapp/storage/pdfs/.gitkeep

# PostgreSQL-Volume (nie kopieren — nur pg_dump verwenden)
/opt/

# ═══════════════════════════════════════════════════════
# Betriebssystem / Editor
# ═══════════════════════════════════════════════════════

.DS_Store
.AppleDouble
.idea/
.vscode/
*.swp
*.swo

# ═══════════════════════════════════════════════════════
# Laufzeit
# ═══════════════════════════════════════════════════════

*.log
__pycache__/
*.pyc
*.pyo
.venv/
venv/
node_modules/

# Traefik ACME-Zertifikate (lokal generiert, nicht versionieren)
/docker/traefik/letsencrypt/
