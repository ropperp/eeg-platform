.env

# Daten (Volumes auf dem Server, kein Git)
/opt/
backups/

# Logs
*.log

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Node
node_modules/

# macOS
.DS_Store
.AppleDouble

